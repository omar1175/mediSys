# ──────────────────────────────────────────────
# MediSys — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# The backend reads these via settings_dev.py (development)
# or settings_prod.py (production).
# ──────────────────────────────────────────────

# ── Django Core ───────────────────────────────
SECRET_KEY=django-insecure-replace-me-with-a-real-secret-key
DEBUG=True

# ── Frontend URL (used in email links) ───────
FRONTEND_URL=http://localhost:5173

# ── Allowed Hosts (comma-separated) ──────────
ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS Origins (comma-separated) ───────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Email (Development — Gmail SMTP) ─────────
# Uses Gmail App Password (not your login password).
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=MediSys <your-email@gmail.com>

# ── Email (Production — Anymail / SendGrid) ──
# Uncomment and configure for production deployment.
# EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend
# ANYMAIL_API_KEY=your-sendgrid-api-key
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── Database (Production — PostgreSQL) ────────
# Uncomment and configure for production deployment.
# SQLite is used by default in development (no config needed).
# DB_NAME=medisys
# DB_USER=medisys
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432
