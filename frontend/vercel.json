{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://medisys-api.onrender.com/api/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "https://medisys-api.onrender.com/admin/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
